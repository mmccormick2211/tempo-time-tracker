{
  "__readme": "CUSTOMIZE THIS FILE - Internal activity tickets are mapped from Confluence Tempo Time Tracking - Internal Activities (https://relias.atlassian.net/wiki/x/GABj7). Update SYS-11160 only if your infrastructure ticket changes.",
  "_example_usage": {
    "customize": "Infrastructure ticket can vary by person/team. Internal activity INT tickets follow the Confluence internal activities standard at https://relias.atlassian.net/wiki/x/GABj7.",
    "monthly_reminder": "⚠️ MONTHLY ACTION REQUIRED: At the start of each month, generate a new catchall Ops Jira ticket and update 'meetings-general.jiraTicket' (currently SYS-11160) with the new ticket number.",
    "examples": [
      "Infrastructure: Use 'infra', 'opex', 'infrastructure', 'ops', 'sys' → SYS-11160 (GEN-MAINT)",
      "Standup: Use 'standup', 'daily-standup', 'daily', 'scrum' → INT-14 (INT)",
      "General Meeting (Catchall Ops): Use 'meeting', 'meetings', 'meet' → monthly catchall SYS ticket (GEN-MAINT). ⚠️ Update 'meetings-general.jiraTicket' at the start of each month with the new catchall ticket number.",
      "Platform Deployment: Use 'deployment', 'platform-deployment' → CHM-5981 (GEN-DEV)",
      "1:1 meeting: Use '1:1', '1on1', 'one-on-one', '121' → INT-14 (INT)",
      "Retrospectives: Use 'retro', 'retrospective' → INT-2 (INT)",
      "Professional Development: Use 'pd', 'training', 'learning', 'course' → INT-5 (INT)",
      "Innovation/Hackathon: Use 'innovation', 'hackathon' → INT-6 (INT)",
      "Work-related travel: Use 'travel', 'work-travel' → INT-7 (INT)",
      "Time Off: Use 'pto', 'vacation', 'sick', 'sick-day', 'holiday', 'public-holiday' → INT-8 (INT)",
      "FOH Enablement: Use 'foh', 'enablement' → INT-15 (INT)"
    ],
    "note": "You can log time using ANY alias - they all map to the same category"
  },
  "_instructions": {
    "aliases": "Multiple ways to reference the same work (e.g., '1:1', 'one-on-one', '121' all map to the same category)",
    "defaults": "Optional: defaultDuration, defaultDescription, defaultStartTime for recurring activities",
    "structure": "Each work category contains: aliases (friendly names), jiraTicket, tempoAccount, and optional defaults",
    "usage": "Reference any alias when logging time, and all settings are applied automatically"
  },
